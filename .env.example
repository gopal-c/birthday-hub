# Groq — get from https://console.groq.com
GROQ_API_KEY=gsk_...

# Gmail — enable 2FA then create App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=you@company.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_FROM_NAME=Your Name

# Vercel Postgres (Neon) — auto-populated when you connect a Postgres database in the Vercel dashboard
# For local dev: run `vercel env pull .env.local` after linking the project
POSTGRES_URL=postgres://...

# Cron security — random string to protect the /api/cron endpoint
# CRON_SECRET=change-this-to-a-random-string

# App URL — for production
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
